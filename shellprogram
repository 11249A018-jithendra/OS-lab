//evenodd
#!/bin/bash 
echo "Enter a number:" 
read n 
if [ $((n % 2)) -eq 0 ] 
then 
  echo "The number is Even" 
else 
  echo "The number is Odd" 
fi 

//two biggest 
#!/bin/bash 
echo "Enter first number:" 
read a 
echo "Enter second number:" 
read b 
if [ $a -gt $b ] 
then 
  echo "Biggest number is $a" 
else 
  echo "Biggest number is $b" 
fi 

//three biggest 
#!/bin/bash 
echo "Enter three numbers:" 
read a 
read b 
read c 
 
if [ $a -gt $b ] && [ $a -gt $c ] 
then 
  echo "Biggest number is $a" 
elif [ $b -gt $c ] 
then 
  echo "Biggest number is $b" 
else 
  echo "Biggest number is $c" 
fi 
 
//factorial 
#!/bin/bash 
echo "Enter a number:" 
read n 
fact=1 
for (( i=1; i<=n; i++ )) 
do 
  fact=$((fact * i)) 
done 
echo "Factorial of $n is $fact" 

//fibonacci
#!/bin/bash 
echo "Enter number of terms:" 
read n 
a=0 
b=1 
echo "Fibonacci Series:" 
echo $a 
echo $b 
for (( i=2; i<n; i++ )) 
do 
  c=$((a + b)) 
  echo $c 
  a=$b 
  b=$c 
done
